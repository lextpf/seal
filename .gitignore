# Build output (track the empty dir via .gitkeep; ignore its contents)
build/*
!build/.gitkeep
build-*/

# Generated documentation (main.html is the hand-authored mkdocs theme override)
docs/*
!docs/main.html
site/*
!site/.gitkeep

# Knowledge-graph / analysis output
graphify-out/

# Python
__pycache__/
*.pyc

# Application assets
assets/

# Browser extension / local artifacts
com.seal.fill*.json
*.pem
*.pfx
*.p12
*.crx
*.reg
