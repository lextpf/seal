# clangd configuration for seal.
#
# Why this file exists
# --------------------
# CMakeLists.txt sets CMAKE_EXPORT_COMPILE_COMMANDS ON, but Visual Studio's
# CMake generator silently ignores it - only the Ninja and Makefile
# generators emit compile_commands.json. So if you configured with the
# default `cmake -B build`, build/ has no compile DB, clangd has no per-file
# flags, and most #includes look unresolved even though the project builds.

CompileFlags:
  CompilationDatabase: build-cdb

  Add:
    - -std=c++23
    - --target=x86_64-pc-windows-msvc
    - -fms-extensions
    - -fms-compatibility
    - -fdelayed-template-parsing
    - -Wno-microsoft-include
    - -Wno-pragma-once-outside-header
    - -Wno-unknown-attributes

    # Project defines - mirrors CMakeLists.txt. The global add_compile_definitions
    # contributes NOMINMAX and _CRT_SECURE_NO_WARNINGS; the per-target
    # target_compile_definitions on `seal` add _WIN32_WINNT and USE_QT_UI.
    # seal_tests omits USE_QT_UI, but defining it globally for clangd gives
    # full IDE coverage of the Qt-gated regions of src/* (the bulk of the
    # codebase). Test sources don't include Qt headers, so they're unaffected.
    - -DNOMINMAX
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_WIN32_WINNT=0x0A00
    - -DUSE_QT_UI

    # Project sources. CMake adds CMAKE_CURRENT_SOURCE_DIR (i.e. `.`) to the
    # `seal` target; the `seal_tests` target additionally adds src/ so test
    # files can include project headers by bare name.
    - -I.
    - -Isrc
    - -Itests

    # vcpkg-installed headers - dynamic triplet (default `.\build.bat` output).
    # Qt6 places its forwarding headers (`<QObject>`, `<QString>`, ...) inside
    # per-module subdirs (`include/Qt6/QtCore/QObject`), so each Qt module dir
    # the code touches must be on the include path. OpenCV needs include/opencv4.
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtCore
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtGui
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQml
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuick
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuickControls2
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtWidgets
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/opencv4

    # vcpkg-installed headers - static triplet (`.\build.bat --static` output).
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtCore
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtGui
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQml
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQuick
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQuickControls2
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtWidgets
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/opencv4

    # The `compile-db` Ninja sidecar reuses the same triplet as the default
    # build (x64-windows-release-msvc143) so its packages share the include
    # paths already listed above. No sidecar-specific Add: entries needed.

  Remove:
    # MSVC-only flags clangd's GCC-style parser chokes on if a
    # compile_commands.json from cl.exe is consumed directly.
    - /EHa
    - /EHsc
    - /MP
    - /MD
    - /MDd
    - /MT
    - /MTd
    - /Gd
    - /Gm-
    - /GS
    - /GR
    - /Gy
    - /Oi
    - /Ot
    - /permissive-
    - /Zc*
    - /ZI
    - /Zi
    - /Z7
    - /JMC
    - /sdl
    - /diagnostics:*
    - /Fp*
    - /Fd*
    - /Fo*
    - /FS

Diagnostics:
  # CONTRIBUTING.md prescribes a manual include order, not include-what-you-use,
  # so don't surface include-graph nits.
  UnusedIncludes: None
  MissingIncludes: None
  Suppress:
    - unknown_attribute
    - pp_including_mainfile_in_preamble

Index:
  Background: Build
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
