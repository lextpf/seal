# clangd configuration for seal.
#
# Why this file exists
# --------------------
# CMakeLists.txt does not set CMAKE_EXPORT_COMPILE_COMMANDS, and even if it
# did, build.bat configures with the Visual Studio 17 generator, which
# silently ignores it - only the Ninja and Makefile generators emit
# compile_commands.json. So if you ran `.\build.bat`, build/ has no compile
# DB, clangd has no per-file flags, and most #includes look unresolved even
# though the project builds.
#
# Two ways to get accurate diagnostics:
#
#   (A) Recommended - generate a side-by-side Ninja build that produces
#       compile_commands.json. clangd auto-discovers it via the
#       CompilationDatabase entry below; the main build/ tree is untouched.
#
#       Run from a "x64 Native Tools Command Prompt for VS 2022" with the
#       same MSVC version build.bat pins (14.44 ICEs on Qt6 sources):
#
#         call "%VSINSTALLDIR%VC\Auxiliary\Build\vcvars64.bat" -vcvars_ver=14.43
#         set VCPKG_BUILDTREES_ROOT=C:\b\seal-vcpkg
#         set VCPKG_MAX_CONCURRENCY=1
#         cmake -B build_clangd -G Ninja ^
#               -DCMAKE_TOOLCHAIN_FILE=%VCPKG_ROOT%/scripts/buildsystems/vcpkg.cmake ^
#               -DVCPKG_OVERLAY_TRIPLETS=triplets ^
#               -DVCPKG_TARGET_TRIPLET=x64-windows-release-msvc143
#         cmake --build build_clangd --target seal
#
#       (Re-run the configure step whenever you add new source files.)
#
#       The MAX_PATH redirect (VCPKG_BUILDTREES_ROOT) and single-job vcpkg
#       (VCPKG_MAX_CONCURRENCY=1) mirror build.bat - they are required to
#       build Qt6 via vcpkg on Windows. Don't drop them.
#
#   (B) Skip the Ninja build. The Add: flags below cover C++23 mode, the
#       project's include paths (src/, tests/, vcpkg_installed/Qt6/opencv4),
#       and the runtime defines from CMakeLists.txt. Navigation and most
#       diagnostics work; some MSVC-specific extensions and per-target
#       defines (notably the test target's omission of USE_QT_UI) won't.
#
# If clangd still can't find <Windows.h> / the MSVC STL, point it at cl.exe
# in your editor's clangd args (NOT here - .clangd doesn't accept it):
#
#       --query-driver=C:\\Program*Files*\\Microsoft*Visual*Studio\\**\\cl.exe
#
# When vcpkg is upgraded and the triplet directory name changes, update the
# Ibuild/vcpkg_installed/<triplet>/include paths under Add: below.

CompileFlags:
  CompilationDatabase: build_clangd

  Add:
    - -std=c++23
    - --target=x86_64-pc-windows-msvc
    - -fms-extensions
    - -fms-compatibility
    - -fdelayed-template-parsing
    - -Wno-microsoft-include
    - -Wno-pragma-once-outside-header
    - -Wno-unknown-attributes

    # Project defines - mirrors CMakeLists.txt. The global add_compile_definitions
    # contributes NOMINMAX and _CRT_SECURE_NO_WARNINGS; the per-target
    # target_compile_definitions on `seal` add _WIN32_WINNT and USE_QT_UI.
    # seal_tests omits USE_QT_UI, but defining it globally for clangd gives
    # full IDE coverage of the Qt-gated regions of src/* (the bulk of the
    # codebase). Test sources don't include Qt headers, so they're unaffected.
    - -DNOMINMAX
    - -D_CRT_SECURE_NO_WARNINGS
    - -D_WIN32_WINNT=0x0A00
    - -DUSE_QT_UI

    # Project sources. CMake adds CMAKE_CURRENT_SOURCE_DIR (i.e. `.`) to the
    # `seal` target; the `seal_tests` target additionally adds src/ so test
    # files can include project headers by bare name.
    - -I.
    - -Isrc
    - -Itests

    # vcpkg-installed headers - dynamic triplet (default `.\build.bat` output).
    # Qt6 places its forwarding headers (`<QObject>`, `<QString>`, ...) inside
    # per-module subdirs (`include/Qt6/QtCore/QObject`), so each Qt module dir
    # the code touches must be on the include path. OpenCV needs include/opencv4.
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtCore
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtGui
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQml
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuick
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuickControls2
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtWidgets
    - -Ibuild/vcpkg_installed/x64-windows-release-msvc143/include/opencv4

    # vcpkg-installed headers - static triplet (`.\build.bat --static` output).
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtCore
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtGui
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQml
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQuick
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtQuickControls2
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/Qt6/QtWidgets
    - -Ibuild/vcpkg_installed/x64-windows-static-release-msvc143/include/opencv4

    # vcpkg-installed headers - side-by-side Ninja build for compile DB
    # (option A above). Same triplet, different output tree.
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtCore
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtGui
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQml
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuick
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtQuickControls2
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/Qt6/QtWidgets
    - -Ibuild_clangd/vcpkg_installed/x64-windows-release-msvc143/include/opencv4

  Remove:
    # MSVC-only flags clangd's GCC-style parser chokes on if a
    # compile_commands.json from cl.exe is consumed directly.
    - /EHa
    - /EHsc
    - /MP
    - /MD
    - /MDd
    - /MT
    - /MTd
    - /Gd
    - /Gm-
    - /GS
    - /GR
    - /Gy
    - /Oi
    - /Ot
    - /permissive-
    - /Zc*
    - /ZI
    - /Zi
    - /Z7
    - /JMC
    - /sdl
    - /diagnostics:*
    - /external:*
    - -external:*
    - /Fp*
    - /Fd*
    - /Fo*
    - /FS

Diagnostics:
  # CONTRIBUTING.md prescribes a manual include order, not include-what-you-use,
  # so don't surface include-graph nits.
  UnusedIncludes: None
  MissingIncludes: None
  Suppress:
    - unknown_attribute
    - pp_including_mainfile_in_preamble

Index:
  Background: Build
  StandardLibrary: Yes

InlayHints:
  Enabled: Yes
  ParameterNames: Yes
  DeducedTypes: Yes
  Designators: Yes

Hover:
  ShowAKA: Yes

Completion:
  AllScopes: Yes
